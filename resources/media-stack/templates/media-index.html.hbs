<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{features.media_services.ui_homepage_title}}</title>
  <style>
    :root { color-scheme: dark light; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; max-width: 760px; margin: 2rem auto; padding: 0 1rem; line-height: 1.5; }
    h1 { margin: 0 0 1rem; }
    .warning { margin: 0 0 1rem; padding: .9rem 1rem; border: 1px solid #d97706; border-radius: 10px; background: rgba(217, 119, 6, 0.12); color: inherit; }
    .warning strong { display: block; margin-bottom: .25rem; }
    .warning.ok { border-color: #15803d; background: rgba(21, 128, 61, 0.12); }
    .warning.warn { border-color: #d97706; }
    .warning.critical { border-color: #b91c1c; background: rgba(185, 28, 28, 0.14); }
    .warning .muted { display: block; margin-top: .25rem; opacity: .82; }
    ul { list-style: none; padding: 0; margin: 0; }
    li { margin: .75rem 0; padding: .75rem; border: 1px solid #8884; border-radius: 8px; }
    a { font-weight: 600; text-decoration: none; }
    p { margin: .25rem 0 0; color: #666; }
  </style>
</head>
<body>
  <h1>{{features.media_services.ui_homepage_title}}</h1>
  <div class="warning warn" id="storage-warning" role="note" aria-live="polite">
    <strong>Local storage warning</strong>
    <span id="storage-warning-text">Loading current /data usage...</span>
    <span class="muted">The media stack is still on local VM storage until the NAS migration lands.</span>
  </div>
  <div class="warning" role="note" aria-live="polite">
    <strong>Generated artifact warning</strong>
    <span>This page reflects generated vmctl artifacts from the last successful render. If services or templates changed while an apply was already running, rerun <code>vmctl apply</code> so the rendered <code>.env</code> and bootstrap files are rebuilt together.</span>
  </div>
  <ul>
    {{#each ui_services}}
    <li>
      <a href="#" data-service-name="{{this.name}}" data-service-port="{{this.port}}" data-service-path="{{this.path}}">{{this.name}}</a>
      <p>{{this.description}}</p>
    </li>
    {{/each}}
    <li>
      <a id="jellio-manifest-tailscale-link" href="#">Stremio Manifest (Tailscale)</a>
      <p>Primary manifest for private access via Tailscale MagicDNS + Tailscale Serve.</p>
    </li>
    <li>
      <a id="jellio-manifest-cloudflare-link" href="#">Stremio Manifest (Cloudflare optional)</a>
      <p>Only active when Cloudflare tunnel is explicitly configured.</p>
    </li>
    <li>
      <a id="compatibility-summary-link" href="#">Media Compatibility Summary</a>
      <p>Generated by the unpack/recovery pass when files need remuxing or transcoding for Stremio.</p>
    </li>
  </ul>
  <script>
    (function () {
      var host = window.location.hostname;
      var links = document.querySelectorAll("a[data-service-port]");
      links.forEach(function (link) {
        var port = link.getAttribute("data-service-port");
        var path = link.getAttribute("data-service-path") || "/";
        if (!path.startsWith("/")) path = "/" + path;
        if (!port) return;
        link.href = "http://" + host + ":" + port + path;
      });

      function wire(id, path) {
        fetch(path, { cache: "no-store" })
          .then(function (res) { return res.ok ? res.text() : ""; })
          .then(function (text) {
            var link = document.getElementById(id);
            if (!link) return;
            var url = (text || "").trim();
            if (!url) {
              link.style.opacity = "0.4";
              link.style.pointerEvents = "none";
              return;
            }
            link.href = url;
          })
          .catch(function () {});
      }
      wire("jellio-manifest-tailscale-link", "/jellio-manifest.tailscale.url");
      wire("jellio-manifest-cloudflare-link", "/jellio-manifest.cloudflare.url");
      wire("compatibility-summary-link", "/compatibility-summary.txt");

      fetch("/storage-health.json", { cache: "no-store" })
        .then(function (res) { return res.ok ? res.json() : null; })
        .then(function (data) {
          var banner = document.getElementById("storage-warning");
          var text = document.getElementById("storage-warning-text");
          if (!banner || !text || !data) return;

          var totalGb = Number(data.totalGb || data.total_gb || 0);
          var usedGb = Number(data.usedGb || data.used_gb || 0);
          var freeGb = Number(data.freeGb || data.free_gb || 0);
          var usedPercent = Number(data.usedPercent || data.used_percent || 0);
          var storagePath = String(data.storagePath || data.storage_path || "/data");
          function fmt(value) {
            if (!isFinite(value)) return "0";
            return value.toFixed(1).replace(/\.0$/, "");
          }

          var severity = "ok";
          if (usedPercent >= 90) severity = "critical";
          else if (usedPercent >= 80) severity = "warn";
          banner.className = "warning " + severity;
          text.innerHTML =
            "Current usage for <code>" + storagePath + "</code>: " +
            "<strong>" + fmt(usedGb) + " GB used</strong> of <strong>" + fmt(totalGb) + " GB total</strong> " +
            "(" + fmt(freeGb) + " GB free, " + usedPercent.toFixed(1) + "% used)." +
            (usedPercent >= 80
              ? " Free space is getting tight; Radarr and Sonarr may stall if the disk fills."
              : " Keep the VM disk at 200 GB or larger until the data moves to NAS.");
        })
        .catch(function () {
          var text = document.getElementById("storage-warning-text");
          if (text) {
            text.textContent = "Unable to read live disk usage right now. The current /data mount should remain at 200 GB or larger.";
          }
        });

      fetch("/jellyfin-autologin.url", { cache: "no-store" })
        .then(function (res) { return res.ok ? res.text() : ""; })
        .then(function (text) {
          var url = (text || "").trim();
          if (!url) return;
          var jellyfinLink = document.querySelector('a[data-service-name="Jellyfin"]');
          if (jellyfinLink) jellyfinLink.href = url;
        })
        .catch(function () {});
    })();
  </script>
</body>
</html>
