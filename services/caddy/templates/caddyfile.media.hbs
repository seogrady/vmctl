{
  auto_https off
}

:80 {
  handle_path /healthz {
    respond "ok" 200
  }

  header -Strict-Transport-Security

  log {
    output stdout
    format console
  }

  # Short Jellio alias routes (work around Stremio manifest URL length limits).
  #
  # These paths are rewritten to the full `/jellio/<b64>/...` routes which are generated by
  # `bootstrap-jellio.sh`. Without this, Tailscale manifests can exceed typical URL length limits
  # in some Stremio clients.
  handle_path /jellio-tailscale/* {
    header {
      Access-Control-Allow-Origin *
      Access-Control-Allow-Methods "GET,HEAD,OPTIONS"
      Access-Control-Allow-Headers *
    }
    rewrite * /jf/jellio/{$JELLIO_CONFIG_B64_TAILSCALE}{path}?{query}
    reverse_proxy jellio-shim:8098 {
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto https
      header_down -Access-Control-Allow-Origin
      header_down -Access-Control-Allow-Methods
      header_down -Access-Control-Allow-Headers
    }
  }

  handle_path /jellio-cloudflare/* {
    rewrite * /jf/jellio/{$JELLIO_CONFIG_B64_CLOUDFLARE}{path}?{query}
    reverse_proxy {$JELLYFIN_INTERNAL_URL}
  }

  @tailscale_jellio {
    host *.*.ts.net
    path /jellio/*
  }

  @tailscale_tizen_jellio {
    host *.*.ts.net
    header_regexp User-Agent (?i).*tizen.*
    path /jellio/*
  }

  @tizen_jellio {
    header_regexp User-Agent (?i).*tizen.*
    path /jellio/*
  }

  @tizen_stream {
    header_regexp User-Agent (?i).*tizen.*
    path_regexp tizen_stream ^/[Vv]ideos/([^/]+)/stream$
  }

  @tizen_jf_stream {
    header_regexp User-Agent (?i).*tizen.*
    path_regexp tizen_jf_stream ^/jf/[Vv]ideos/([^/]+)/stream$
  }

  # Stremio playback should favor HLS on the Jellyfin proxy path so clients
  # get a format that is broadly compatible and less likely to fall back to a
  # heavy direct-transcode path.
  @jf_stream {
    path_regexp jf_stream ^/jf/[Vv]ideos/([^/]+)/stream$
  }

  @jellyfin_stream {
    path_regexp jellyfin_stream ^/[Vv]ideos/([^/]+)/stream$
  }

  handle @tizen_stream {
    rewrite * /Videos/{re.tizen_stream.1}/master.m3u8?{query}
    reverse_proxy {$JELLYFIN_INTERNAL_URL} {
      header_up Accept-Encoding identity
      header_up X-MediaBrowser-Token {$JELLYFIN_STREMIO_AUTH_TOKEN}
    }
  }

  handle @tizen_jf_stream {
    rewrite * /jf/Videos/{re.tizen_jf_stream.1}/master.m3u8?{query}
    reverse_proxy {$JELLYFIN_INTERNAL_URL} {
      header_up Accept-Encoding identity
      header_up X-MediaBrowser-Token {$JELLYFIN_STREMIO_AUTH_TOKEN}
    }
  }

  handle @jf_stream {
    rewrite * /jf/Videos/{re.jf_stream.1}/master.m3u8?{query}
    reverse_proxy {$JELLYFIN_INTERNAL_URL} {
      header_up Accept-Encoding identity
      header_up X-MediaBrowser-Token {$JELLYFIN_STREMIO_AUTH_TOKEN}
    }
  }

  handle @jellyfin_stream {
    rewrite * /Videos/{re.jellyfin_stream.1}/master.m3u8?{query}
    reverse_proxy {$JELLYFIN_INTERNAL_URL} {
      header_up Accept-Encoding identity
      header_up X-MediaBrowser-Token {$JELLYFIN_STREMIO_AUTH_TOKEN}
    }
  }

  handle @tailscale_tizen_jellio {
    # Proxy Jellio JSON via a shim that rewrites http://<host> -> https://<host>.
    rewrite * /jf{uri}
    reverse_proxy jellio-shim:8098 {
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto https
    }
  }

  handle @tailscale_jellio {
    rewrite * /jf{uri}
    reverse_proxy jellio-shim:8098 {
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto https
    }
  }

  handle @tizen_jellio {
    rewrite * /jf{uri}
    reverse_proxy {$JELLYFIN_INTERNAL_URL} {
      header_up Accept-Encoding identity
    }
  }

  handle /jellio/* {
    rewrite * /jf{uri}
    reverse_proxy {$JELLYFIN_INTERNAL_URL}
  }

  handle /jf/* {
    reverse_proxy {$JELLYFIN_INTERNAL_URL} {
      header_up X-MediaBrowser-Token {$JELLYFIN_STREMIO_AUTH_TOKEN}
    }
  }

  handle /Items/* {
    reverse_proxy {$JELLYFIN_INTERNAL_URL} {
      header_up X-MediaBrowser-Token {$JELLYFIN_STREMIO_AUTH_TOKEN}
    }
  }

  handle /items/* {
    reverse_proxy {$JELLYFIN_INTERNAL_URL} {
      header_up X-MediaBrowser-Token {$JELLYFIN_STREMIO_AUTH_TOKEN}
    }
  }

  handle /Videos/* {
    reverse_proxy {$JELLYFIN_INTERNAL_URL} {
      header_up X-MediaBrowser-Token {$JELLYFIN_STREMIO_AUTH_TOKEN}
    }
  }

  handle /videos/* {
    reverse_proxy {$JELLYFIN_INTERNAL_URL} {
      header_up X-MediaBrowser-Token {$JELLYFIN_STREMIO_AUTH_TOKEN}
    }
  }

  handle {
    root * /srv/ui-index
    file_server
  }
}

:5056 {
  encode gzip
  reverse_proxy seerr:5055
}

:7474 {
  encode gzip
  reverse_proxy autobrr:7474
}

:8097 {
  encode gzip
  reverse_proxy {$JELLYFIN_INTERNAL_URL} {
    header_up X-MediaBrowser-Token {$JELLYFIN_AUTO_AUTH_TOKEN}
  }
}
