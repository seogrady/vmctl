:80 {
  encode gzip

  handle_path /healthz {
    respond "ok" 200
  }

  handle /jellio/* {
    reverse_proxy {$JELLYFIN_INTERNAL_URL}
  }

  handle {
    root * /srv/ui-index
    file_server
  }
}

:5056 {
  encode gzip
  reverse_proxy jellyseerr:5055 {
    header_up X-API-Key {$JELLYSEERR_API_KEY}
  }
}

:8097 {
  encode gzip
  reverse_proxy {$JELLYFIN_INTERNAL_URL} {
    header_up X-MediaBrowser-Token {$JELLYFIN_AUTO_AUTH_TOKEN}
  }
}
