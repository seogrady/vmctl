<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{features.media_services.ui_homepage_title}}</title>
  <style>
    :root { color-scheme: dark light; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; max-width: 760px; margin: 2rem auto; padding: 0 1rem; line-height: 1.5; }
    h1 { margin: 0 0 1rem; }
    ul { list-style: none; padding: 0; margin: 0; }
    li { margin: .75rem 0; padding: .75rem; border: 1px solid #8884; border-radius: 8px; }
    a { font-weight: 600; text-decoration: none; }
    p { margin: .25rem 0 0; color: #666; }
  </style>
</head>
<body>
  <h1>{{features.media_services.ui_homepage_title}}</h1>
  <ul>
    {{#each ui_services}}
    <li>
      <a href="#" data-service-port="{{this.port}}" data-service-path="{{this.path}}">{{this.name}}</a>
      <p>{{this.description}}</p>
    </li>
    {{/each}}
    <li>
      <a id="jellio-manifest-lan-link" href="#">Stremio Manifest (LAN)</a>
      <p>Use this on LAN devices that can install HTTP addon manifests.</p>
    </li>
    <li>
      <a id="jellio-manifest-tailnet-link" href="#">Stremio Manifest (Tailnet)</a>
      <p>Primary manifest for private HTTPS access over Tailscale.</p>
    </li>
    <li>
      <a id="jellio-manifest-cloudflare-link" href="#">Stremio Manifest (Cloudflare optional)</a>
      <p>Only active when Cloudflare tunnel is explicitly configured.</p>
    </li>
    <li>
      <a id="jellyfin-auto-link" href="#">Jellyfin (Auto Auth)</a>
      <p>Auto-authenticated Jellyfin endpoint for LAN/Tailscale access.</p>
    </li>
    <li>
      <a id="jellyseerr-auto-link" href="#">Jellyseerr (Auto Auth)</a>
      <p>Auto-authenticated Jellyseerr endpoint for LAN/Tailscale access.</p>
    </li>
  </ul>
  <script>
    (function () {
      var host = window.location.hostname;
      var links = document.querySelectorAll("a[data-service-port]");
      links.forEach(function (link) {
        var port = link.getAttribute("data-service-port");
        var path = link.getAttribute("data-service-path") || "/";
        if (!path.startsWith("/")) path = "/" + path;
        if (!port) return;
        link.href = "http://" + host + ":" + port + path;
      });

      function wire(id, path) {
        fetch(path, { cache: "no-store" })
          .then(function (res) { return res.ok ? res.text() : ""; })
          .then(function (text) {
            var link = document.getElementById(id);
            if (!link) return;
            var url = (text || "").trim();
            if (!url) {
              link.style.opacity = "0.4";
              link.style.pointerEvents = "none";
              return;
            }
            link.href = url;
          })
          .catch(function () {});
      }
      wire("jellio-manifest-lan-link", "/jellio-manifest.lan.url");
      wire("jellio-manifest-tailnet-link", "/jellio-manifest.tailnet.url");
      wire("jellio-manifest-cloudflare-link", "/jellio-manifest.cloudflare.url");

      var jellyfinAuto = document.getElementById("jellyfin-auto-link");
      if (jellyfinAuto) jellyfinAuto.href = "http://" + host + ":8097";
      var jellyseerrAuto = document.getElementById("jellyseerr-auto-link");
      if (jellyseerrAuto) jellyseerrAuto.href = "http://" + host + ":5056";
    })();
  </script>
</body>
</html>
