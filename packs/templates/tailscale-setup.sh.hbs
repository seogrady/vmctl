#!/usr/bin/env bash
set -euo pipefail

VMCTL_TAILSCALE_ENABLED={{#if tailscale.enabled}}1{{else}}0{{/if}}
if [[ "$VMCTL_TAILSCALE_ENABLED" != "1" ]]; then
  echo "tailscale disabled for this resource"
  exit 0
fi

args=(--reset --auth-key "{{tailscale.auth_key}}")
{{#if tailscale.hostname}}
args+=(--hostname "{{tailscale.hostname}}")
{{/if}}
{{#if tailscale.advertise_routes}}
args+=(--advertise-routes "{{tailscale.advertise_routes}}")
{{/if}}
{{#if tailscale.advertise_exit_node}}
args+=(--advertise-exit-node)
{{/if}}
{{#if tailscale.accept_routes}}
args+=(--accept-routes)
{{/if}}
{{#if tailscale.tags}}
args+=(--advertise-tags "{{tailscale.tags}}")
{{/if}}

{{#if tailscale.advertise_routes}}
cat >/etc/sysctl.d/99-tailscale-forwarding.conf <<'EOF'
net.ipv4.ip_forward = 1
net.ipv6.conf.all.forwarding = 1
EOF
sysctl -w net.ipv4.ip_forward=1
sysctl -w net.ipv6.conf.all.forwarding=1
{{/if}}
{{#if tailscale.advertise_exit_node}}
cat >/etc/sysctl.d/99-tailscale-forwarding.conf <<'EOF'
net.ipv4.ip_forward = 1
net.ipv6.conf.all.forwarding = 1
EOF
sysctl -w net.ipv4.ip_forward=1
sysctl -w net.ipv6.conf.all.forwarding=1
{{/if}}

tailscale up "${args[@]}"
