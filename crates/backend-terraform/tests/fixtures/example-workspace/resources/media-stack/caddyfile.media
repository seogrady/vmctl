{
  auto_https off
}

media-stack:80, media-stack.home.arpa:80, :80 {
  handle_path /healthz {
    respond "ok" 200
  }

  header -Strict-Transport-Security

  log {
    output stdout
    format console
  }

  @tizen_jellio {
    header_regexp User-Agent (?i).*tizen.*
    path /jellio/*
  }

  @tizen_stream {
    header_regexp User-Agent (?i).*tizen.*
    path_regexp tizen_stream ^/[Vv]ideos/([^/]+)/stream$
  }

  @tizen_jf_stream {
    header_regexp User-Agent (?i).*tizen.*
    path_regexp tizen_jf_stream ^/jf/[Vv]ideos/([^/]+)/stream$
  }

  handle @tizen_stream {
    rewrite * /Videos/{re.tizen_stream.1}/master.m3u8
    reverse_proxy {$JELLYFIN_INTERNAL_URL} {
      header_up Accept-Encoding identity
      header_up X-MediaBrowser-Token {$JELLYFIN_STREMIO_AUTH_TOKEN}
    }
  }

  handle @tizen_jf_stream {
    rewrite * /Videos/{re.tizen_jf_stream.1}/master.m3u8
    reverse_proxy {$JELLYFIN_INTERNAL_URL} {
      header_up Accept-Encoding identity
      header_up X-MediaBrowser-Token {$JELLYFIN_STREMIO_AUTH_TOKEN}
    }
  }

  handle @tizen_jellio {
    reverse_proxy {$JELLYFIN_INTERNAL_URL} {
      header_up Accept-Encoding identity
    }
  }

  handle /jellio/* {
    reverse_proxy {$JELLYFIN_INTERNAL_URL}
  }

  handle_path /jf/* {
    reverse_proxy {$JELLYFIN_INTERNAL_URL} {
      header_up X-MediaBrowser-Token {$JELLYFIN_STREMIO_AUTH_TOKEN}
    }
  }

  handle /Items/* {
    reverse_proxy {$JELLYFIN_INTERNAL_URL} {
      header_up X-MediaBrowser-Token {$JELLYFIN_STREMIO_AUTH_TOKEN}
    }
  }

  handle /items/* {
    reverse_proxy {$JELLYFIN_INTERNAL_URL} {
      header_up X-MediaBrowser-Token {$JELLYFIN_STREMIO_AUTH_TOKEN}
    }
  }

  handle /Videos/* {
    reverse_proxy {$JELLYFIN_INTERNAL_URL} {
      header_up X-MediaBrowser-Token {$JELLYFIN_STREMIO_AUTH_TOKEN}
    }
  }

  handle /videos/* {
    reverse_proxy {$JELLYFIN_INTERNAL_URL} {
      header_up X-MediaBrowser-Token {$JELLYFIN_STREMIO_AUTH_TOKEN}
    }
  }

  handle {
    root * /srv/ui-index
    file_server
  }
}

:5056 {
  encode gzip
  reverse_proxy jellyseerr:5055
}

:8097 {
  encode gzip
  reverse_proxy {$JELLYFIN_INTERNAL_URL} {
    header_up X-MediaBrowser-Token {$JELLYFIN_AUTO_AUTH_TOKEN}
  }
}
