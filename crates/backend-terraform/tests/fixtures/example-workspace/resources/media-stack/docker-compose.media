services:
  caddy:
    image: "caddy:2"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "80:80"
      - "5056:5056"
      - "8097:8097"
    volumes:
      - "${CONFIG_PATH}/caddy/Caddyfile:/etc/caddy/Caddyfile:ro"
      - "${CONFIG_PATH}/caddy/ui-index:/srv/ui-index:ro"
    environment:
      - "JELLYFIN_AUTO_AUTH_TOKEN=${JELLYFIN_AUTO_AUTH_TOKEN}"
      - "JELLYFIN_STREMIO_AUTH_TOKEN=${JELLYFIN_STREMIO_AUTH_TOKEN}"
      - "SEERR_API_KEY=${SEERR_API_KEY}"
  jellio-shim:
    image: "python:3.13-alpine"
    env_file:
      - .env
    restart: unless-stopped
    command: python3 /app/jellio-shim.py
    volumes:
      - "${CONFIG_PATH}/jellio-shim:/app:ro"
    environment:
      - "JELLIO_SHIM_LISTEN=0.0.0.0:8098"
      - "JELLIO_SHIM_UPSTREAM=${JELLYFIN_INTERNAL_URL}"
  jellyfin:
    image: "lscr.io/linuxserver/jellyfin:latest"
    env_file:
      - .env
    restart: unless-stopped
    network_mode: "host"
    group_add:
      - 992
    devices:
      - "/dev/dri:/dev/dri"
    volumes:
      - "${STORAGE_PATH}:/data"
      - "${CONFIG_PATH}/jellyfin:/config"
      - "/etc/OpenCL/vendors:/etc/OpenCL/vendors:ro"
      - "/usr/lib/x86_64-linux-gnu/intel-opencl:/usr/lib/x86_64-linux-gnu/intel-opencl:ro"
      - "/usr/lib/x86_64-linux-gnu/libocloc_legacy1.so:/usr/lib/x86_64-linux-gnu/libocloc_legacy1.so:ro"
      - "/lib/x86_64-linux-gnu/libigdgmm.so.12:/lib/x86_64-linux-gnu/libigdgmm.so.12:ro"
      - "/usr/local/lib:/usr/local/lib:ro"
  meilisearch:
    image: "getmeili/meilisearch:v1.9"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "7700:7700"
    volumes:
      - "${CONFIG_PATH}/meilisearch:/meili_data"
    environment:
      - "MEILI_MASTER_KEY=${MEILI_MASTER_KEY}"
  jellysearch:
    image: "domistyle/jellysearch:latest"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "5000:5000"
    volumes:
      - "${CONFIG_PATH}/jellyfin:/config:ro"
    environment:
      - "INDEX_CRON=0 0/5 * ? * * *"
      - "JELLYFIN_CONFIG_DIR=/config"
      - "JELLYFIN_URL=${JELLYFIN_INTERNAL_URL}"
      - "MEILI_MASTER_KEY=${MEILI_MASTER_KEY}"
      - "MEILI_URL=http://meilisearch:7700"
  recyclarr:
    image: "ghcr.io/recyclarr/recyclarr:latest"
    env_file:
      - .env
    restart: unless-stopped
    entrypoint: /bin/sh
    command: /config/recyclarr-loop.sh
    volumes:
      - "${CONFIG_PATH}/recyclarr:/config"
  sabnzbd:
    image: "lscr.io/linuxserver/sabnzbd:latest"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "8085:8080"
    volumes:
      - "${STORAGE_PATH}:/data"
      - "${CONFIG_PATH}/sabnzbd:/config"
  autobrr:
    image: "ghcr.io/autobrr/autobrr:latest"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "7474:7474"
    volumes:
      - "${CONFIG_PATH}/autobrr:/config"
    environment:
      - "AUTOBRR__BASE_URL=/autobrr/"
      - "AUTOBRR__BASE_URL_MODE_LEGACY=false"
      - "AUTOBRR__CUSTOM_DEFINITIONS=${AUTOBRR_CUSTOM_DEFINITIONS}"
      - "AUTOBRR__HOST=0.0.0.0"
      - "AUTOBRR__LOG_LEVEL=info"
      - "AUTOBRR__PORT=7474"
      - "AUTOBRR__SESSION_SECRET=${AUTOBRR_SESSION_SECRET}"
  sonarr:
    image: "lscr.io/linuxserver/sonarr:latest"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "8989:8989"
    volumes:
      - "${STORAGE_PATH}:/data"
      - "${CONFIG_PATH}/sonarr:/config"
  radarr:
    image: "lscr.io/linuxserver/radarr:latest"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "7878:7878"
    volumes:
      - "${STORAGE_PATH}:/data"
      - "${CONFIG_PATH}/radarr:/config"
  prowlarr:
    image: "lscr.io/linuxserver/prowlarr:latest"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "9696:9696"
    volumes:
      - "${CONFIG_PATH}/prowlarr:/config"
  flaresolverr:
    image: "ghcr.io/flaresolverr/flaresolverr:v3.4.6"
    env_file:
      - .env
    restart: unless-stopped
    environment:
      - "LOG_LEVEL=info"
      - "TZ=${TZ}"
  qbittorrent-vpn:
    image: "lscr.io/linuxserver/qbittorrent:latest"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "8080:8080"
      - "6881:6881"
      - "6881:6881/udp"
    volumes:
      - "${STORAGE_PATH}:/data"
      - "${CONFIG_PATH}/qbittorrent:/config"
  seerr:
    image: "ghcr.io/seerr-team/seerr:v3.2.0"
    env_file:
      - .env
    restart: unless-stopped
    init: true
    ports:
      - "5055:5055"
    volumes:
      - "${CONFIG_PATH}/seerr:/app/config"
    environment:
      - "API_KEY=${SEERR_API_KEY}"
  bazarr:
    image: "lscr.io/linuxserver/bazarr:latest"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "6767:6767"
    volumes:
      - "${STORAGE_PATH}:/data"
      - "${CONFIG_PATH}/bazarr:/config"
  jellystat-db:
    image: "postgres:15-alpine"
    env_file:
      - .env
    restart: unless-stopped
    volumes:
      - "${CONFIG_PATH}/jellystat-db:/var/lib/postgresql/data"
  jellystat:
    image: "cyfershepard/jellystat:latest"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "3000:3000"
    volumes:
      - "${CONFIG_PATH}/jellystat:/app/backend/backup-data"
