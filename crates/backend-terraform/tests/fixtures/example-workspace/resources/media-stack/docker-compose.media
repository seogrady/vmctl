services:
  caddy:
    image: "caddy:2"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "80:80"
    volumes:
      - "${CONFIG_PATH}/caddy/Caddyfile:/etc/caddy/Caddyfile:ro"
      - "${CONFIG_PATH}/caddy/ui-index:/srv/ui-index:ro"
  jellyfin:
    image: "lscr.io/linuxserver/jellyfin:latest"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "8096:8096"
    volumes:
      - "${MEDIA_PATH}:/media"
      - "${CONFIG_PATH}/jellyfin:/config"
  sonarr:
    image: "lscr.io/linuxserver/sonarr:latest"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "8989:8989"
    volumes:
      - "${MEDIA_PATH}:/media"
      - "${CONFIG_PATH}/sonarr:/config"
  radarr:
    image: "lscr.io/linuxserver/radarr:latest"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "7878:7878"
    volumes:
      - "${MEDIA_PATH}:/media"
      - "${CONFIG_PATH}/radarr:/config"
  prowlarr:
    image: "lscr.io/linuxserver/prowlarr:latest"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "9696:9696"
    volumes:
      - "${CONFIG_PATH}/prowlarr:/config"
  qbittorrent-vpn:
    image: "lscr.io/linuxserver/qbittorrent:latest"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "8080:8080"
      - "6881:6881"
      - "6881:6881/udp"
    volumes:
      - "${MEDIA_PATH}:/media"
      - "${CONFIG_PATH}/qbittorrent:/config"
  jellyseerr:
    image: "fallenbagel/jellyseerr:latest"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "5055:5055"
    volumes:
      - "${CONFIG_PATH}/jellyseerr:/app/config"
  bazarr:
    image: "lscr.io/linuxserver/bazarr:latest"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "6767:6767"
    volumes:
      - "${MEDIA_PATH}:/media"
      - "${CONFIG_PATH}/bazarr:/config"
  homarr:
    image: "ghcr.io/homarr-labs/homarr:latest"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "7575:7575"
    volumes:
      - "${CONFIG_PATH}/homarr:/appdata"
  jellystat-db:
    image: "postgres:15-alpine"
    env_file:
      - .env
    restart: unless-stopped
    volumes:
      - "${CONFIG_PATH}/jellystat-db:/var/lib/postgresql/data"
  jellystat:
    image: "cyfershepard/jellystat:latest"
    env_file:
      - .env
    restart: unless-stopped
    ports:
      - "3000:3000"
    volumes:
      - "${CONFIG_PATH}/jellystat:/app/backend/backup-data"
