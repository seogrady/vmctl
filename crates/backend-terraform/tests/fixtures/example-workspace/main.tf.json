{
  "locals": {
    "vmctl_resource_count": "${length(var.resources)}",
    "vmctl_resource_names": "${[for resource in var.resources : resource.name]}"
  },
  "module": {
    "media_stack": {
      "bridge": "vmbr0",
      "depends_on": [
        "module.tailscale_gateway",
        "proxmox_virtual_environment_download_file.image_ubuntu_24_cloud_image"
      ],
      "node_name": "mini",
      "resource": {
        "agent": true,
        "bridge": "vmbr0",
        "clone_vmid": null,
        "cloud_init": {
          "ssh_key_file": "/home/me/.ssh/id_ed25519.pub",
          "user": "ubuntu"
        },
        "cores": 6,
        "depends_on": [
          "tailscale-gateway"
        ],
        "description": "Media stack VM managed by vmctl",
        "disk_gb": 64,
        "disk_interface": null,
        "features": {
          "docker": {
            "enabled": true
          },
          "intel_igpu": {
            "enabled": true,
            "mapping": "intel-igpu",
            "pci_device": "00:02.0"
          },
          "media_services": {
            "enabled": true,
            "minimal": true,
            "services": [
              "jellyfin",
              "sonarr",
              "radarr",
              "prowlarr",
              "qbittorrent"
            ]
          },
          "tailscale": {
            "auth_key": "<redacted>",
            "enabled": true,
            "mode": "client",
            "tags": [
              "tag:homelab"
            ]
          }
        },
            "hostname": null,
        "image": "ubuntu_24_cloud_image",
        "iothread": null,
        "kind": "vm",
        "machine": "q35",
        "memory": 8192,
        "name": "media-stack",
        "nameserver": "1.1.1.1",
        "network": {
          "address": null,
          "firewall": null,
          "gateway": null,
          "mac": null,
          "mode": "dhcp",
          "mtu": null,
          "vlan_id": null
        },
        "node": null,
        "os_type": null,
        "provision": {
              "host": "media-stack",
          "private_key_file": "<redacted>",
          "retries": 20,
          "retry_delay_seconds": 15,
          "user": "ubuntu"
        },
        "role": "media_stack",
        "rootfs_gb": null,
        "scsi_hardware": null,
        "searchdomain": "home.arpa",
        "start_on_boot": true,
        "storage": "local-lvm",
        "tags": [
          "vmctl",
          "homelab"
        ],
        "template": "local:import/noble-server-cloudimg-amd64.qcow2",
        "template_storage": null,
        "vmid": 210
      },
      "source": "./modules/vm",
      "storage": "local-lvm",
      "template": "${proxmox_virtual_environment_download_file.image_ubuntu_24_cloud_image.id}"
    },
    "tailscale_gateway": {
      "bridge": "vmbr0",
      "node_name": "mini",
      "resource": {
        "agent": true,
        "bridge": "vmbr0",
        "clone_vmid": null,
        "cloud_init": {
          "ssh_key_file": "/home/me/.ssh/id_ed25519.pub",
          "user": null
        },
        "cores": 1,
        "depends_on": [],
        "description": "Tailscale subnet router managed by vmctl",
        "disk_gb": null,
        "disk_interface": null,
        "features": {
          "lxc": {
            "nesting": true
          },
          "tailscale": {
            "advertise_routes": [
              "192.168.86.0/24"
            ],
            "auth_key": "<redacted>",
            "enabled": true,
            "exit_node": false,
            "mode": "router",
            "tags": [
              "tag:homelab"
            ]
          }
        },
            "hostname": null,
        "image": "debian_12_lxc",
        "iothread": null,
        "kind": "lxc",
        "machine": null,
        "memory": 1024,
        "name": "tailscale-gateway",
        "nameserver": "1.1.1.1",
        "network": {
          "address": null,
          "firewall": null,
          "gateway": null,
          "mac": null,
          "mode": "dhcp",
          "mtu": null,
          "vlan_id": null
        },
        "node": null,
        "os_type": null,
        "provision": {
              "host": "tailscale-gateway",
          "private_key_file": "<redacted>",
          "retries": 20,
          "retry_delay_seconds": 15,
          "user": "ubuntu"
        },
        "role": "tailscale_gateway",
        "rootfs_gb": 8,
        "scsi_hardware": null,
        "searchdomain": "home.arpa",
        "start_on_boot": true,
        "storage": "local-lvm",
        "tags": [
          "vmctl",
          "homelab"
        ],
        "template": "local:vztmpl/debian-12-standard_12.12-1_amd64.tar.zst",
        "template_storage": null,
        "vmid": 101
      },
      "source": "./modules/lxc",
      "storage": "local-lvm",
      "template": "local:vztmpl/debian-12-standard_12.12-1_amd64.tar.zst"
    }
  },
  "resource": {
    "proxmox_virtual_environment_download_file": {
      "image_ubuntu_24_cloud_image": {
        "content_type": "import",
        "datastore_id": "local",
        "file_name": "noble-server-cloudimg-amd64.qcow2",
        "node_name": "mini",
        "overwrite": true,
        "overwrite_unmanaged": true,
        "url": "https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img"
      }
    }
  },
  "terraform": {
    "required_version": ">= 1.6.0"
  }
}
