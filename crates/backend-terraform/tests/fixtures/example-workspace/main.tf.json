{
  "locals": {
    "vmctl_resource_count": "${length(var.resources)}",
    "vmctl_resource_names": "${[for resource in var.resources : resource.name]}"
  },
  "module": {
    "kodi_htpc": {
      "bridge": "vmbr0",
      "node_name": "mini",
      "resource": {
        "agent": true,
        "bridge": "vmbr0",
        "clone_vmid": null,
        "cloud_init": {
          "ssh_key_file": "/home/me/.ssh/id_ed25519.pub",
          "user": "ubuntu"
        },
        "cores": 4,
        "depends_on": [],
        "description": "Kodi living room HTPC VM managed by vmctl",
        "disk_gb": 32,
        "disk_interface": "scsi0",
        "features": {
          "htpc": {
            "autostart": true,
            "cec": true,
            "enabled": true
          },
          "intel_igpu": {
            "enabled": true,
            "mapping": "intel-igpu",
            "pci_device": "00:02.0"
          },
          "jellyfin": {
            "enabled": true,
            "password": "dummy-jellyfin-password",
            "server_url": "http://media-stack.home.arpa:8096",
            "username": "admin"
          },
          "remote": {
            "enabled": true,
            "event_server_port": 9777,
            "tailscale_https_enabled": true,
            "tailscale_https_target": "http://127.0.0.1:8080",
            "web_port": 8080
          },
          "tailscale": {
            "auth_key": "<redacted>",
            "enabled": true,
            "mode": "client",
            "tags": [
              "tag:homelab"
            ]
          }
        },
        "hostname": null,
        "image": "ubuntu_24_cloud_image",
        "iothread": false,
        "kind": "vm",
        "machine": "q35",
        "memory": 4096,
        "name": "kodi-htpc",
        "nameserver": "1.1.1.1",
        "network": {
          "address": null,
          "firewall": null,
          "gateway": null,
          "mac": null,
          "mode": "dhcp",
          "mtu": null,
          "vlan_id": null
        },
        "node": null,
        "os_type": null,
        "provision": {
          "host": "kodi-htpc",
          "private_key_file": "<redacted>",
          "retries": 20,
          "retry_delay_seconds": 15,
          "user": "ubuntu"
        },
        "role": "kodi_htpc",
        "rootfs_gb": null,
        "scsi_hardware": "virtio-scsi-single",
        "searchdomain": "home.arpa",
        "start_on_boot": true,
        "storage": "local-lvm",
        "tags": [
          "vmctl",
          "homelab"
        ],
        "template": "local:import/noble-server-cloudimg-amd64.qcow2",
        "template_storage": null,
        "vmid": 211
      },
      "source": "./modules/vm",
      "storage": "local-lvm",
      "template": "local:import/noble-server-cloudimg-amd64.qcow2"
    },
    "media_stack": {
      "bridge": "vmbr0",
      "depends_on": [
        "module.tailscale_gateway"
      ],
      "node_name": "mini",
      "resource": {
        "agent": true,
        "bridge": "vmbr0",
        "clone_vmid": null,
        "cloud_init": {
          "ssh_key_file": "/home/me/.ssh/id_ed25519.pub",
          "user": "ubuntu"
        },
        "cores": 6,
        "depends_on": [
          "tailscale-gateway"
        ],
        "description": "Media stack VM managed by vmctl",
        "disk_gb": 64,
        "disk_interface": "scsi0",
        "features": {
          "docker": {
            "enabled": true
          },
          "media_services": {
            "enabled": true,
            "exposure": {
              "tailscale_https_enabled": true,
              "tailscale_https_target": "http://127.0.0.1:80"
            },
            "jellyfin_admin_password": "dummy-jellyfin-password",
            "jellyfin_admin_user": "admin",
            "jellyfin_url": "http://media-stack.home.arpa:8096",
            "minimal": true,
            "services": [
              "caddy",
              "gluetun",
              "jellyfin",
              "sonarr",
              "radarr",
              "prowlarr",
              "qbittorrent-vpn",
              "jellyseerr",
              "bazarr",
              "jellystat-db",
              "jellystat"
            ],
            "ui_homepage_enabled": true,
            "ui_homepage_title": "Media Stack"
          },
          "storage": {
            "media_path": "/media"
          },
          "tailscale": {
            "auth_key": "<redacted>",
            "enabled": true,
            "mode": "client",
            "tags": [
              "tag:homelab"
            ]
          },
          "vpn": {
            "enabled": false,
            "provider": "mullvad",
            "server_cities": "",
            "type": "wireguard",
            "wireguard_addresses": "",
            "wireguard_private_key": "<redacted>"
          }
        },
        "hostname": null,
        "image": "ubuntu_24_cloud_image",
        "iothread": false,
        "kind": "vm",
        "machine": null,
        "memory": 8192,
        "name": "media-stack",
        "nameserver": "1.1.1.1",
        "network": {
          "address": null,
          "firewall": null,
          "gateway": null,
          "mac": null,
          "mode": "dhcp",
          "mtu": null,
          "vlan_id": null
        },
        "node": null,
        "os_type": null,
        "provision": {
          "host": "media-stack",
          "private_key_file": "<redacted>",
          "retries": 20,
          "retry_delay_seconds": 15,
          "user": "ubuntu"
        },
        "role": "media_stack",
        "rootfs_gb": null,
        "scsi_hardware": "virtio-scsi-single",
        "searchdomain": "home.arpa",
        "start_on_boot": true,
        "storage": "local-lvm",
        "tags": [
          "vmctl",
          "homelab"
        ],
        "template": "local:import/noble-server-cloudimg-amd64.qcow2",
        "template_storage": null,
        "vmid": 210
      },
      "source": "./modules/vm",
      "storage": "local-lvm",
      "template": "local:import/noble-server-cloudimg-amd64.qcow2"
    },
    "tailscale_gateway": {
      "bridge": "vmbr0",
      "node_name": "mini",
      "resource": {
        "agent": true,
        "bridge": "vmbr0",
        "clone_vmid": null,
        "cloud_init": {
          "ssh_key_file": "/home/me/.ssh/id_ed25519.pub",
          "user": null
        },
        "cores": 1,
        "depends_on": [],
        "description": "Tailscale subnet router managed by vmctl",
        "disk_gb": null,
        "disk_interface": null,
        "features": {
          "lxc": {
            "nesting": true
          },
          "tailscale": {
            "advertise_routes": [
              "192.168.86.0/24"
            ],
            "auth_key": "<redacted>",
            "enabled": true,
            "exit_node": false,
            "mode": "router",
            "tags": [
              "tag:homelab"
            ]
          }
        },
        "hostname": null,
        "image": "debian_12_lxc",
        "iothread": null,
        "kind": "lxc",
        "machine": null,
        "memory": 1024,
        "name": "tailscale-gateway",
        "nameserver": "1.1.1.1",
        "network": {
          "address": null,
          "firewall": null,
          "gateway": null,
          "mac": null,
          "mode": "dhcp",
          "mtu": null,
          "vlan_id": null
        },
        "node": null,
        "os_type": null,
        "provision": {
          "host": "tailscale-gateway",
          "private_key_file": "<redacted>",
          "retries": 20,
          "retry_delay_seconds": 15,
          "user": "ubuntu"
        },
        "role": "tailscale_gateway",
        "rootfs_gb": 8,
        "scsi_hardware": null,
        "searchdomain": "home.arpa",
        "start_on_boot": true,
        "storage": "local-lvm",
        "tags": [
          "vmctl",
          "homelab"
        ],
        "template": "local:vztmpl/debian-12-standard_12.12-1_amd64.tar.zst",
        "template_storage": null,
        "vmid": 101
      },
      "source": "./modules/lxc",
      "storage": "local-lvm",
      "template": "local:vztmpl/debian-12-standard_12.12-1_amd64.tar.zst"
    }
  },
  "terraform": {
    "required_version": ">= 1.6.0"
  }
}
